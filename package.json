{
  "name": "fidelis-channel",
  "version": "0.5.0",
  "description": "Telegram approval channel for Claude Code with fail-closed permission relay, policy rules, and tamper-evident audit logging.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fidelis-channel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.tests.json",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run build:test && node --test .test-dist/tests/*.test.js"
  },
  "keywords": [
    "claude-code",
    "channels",
    "mcp",
    "telegram",
    "permission-relay",
    "audit-log",
    "security"
  ],
  "author": "TJ Lane <tj@corpussanctum.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/corpussanctum/fidelis-channel.git"
  },
  "homepage": "https://github.com/corpussanctum/fidelis-channel#readme",
  "bugs": {
    "url": "https://github.com/corpussanctum/fidelis-channel/issues"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    "sample-briefcase/",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/post-quantum": "^0.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
